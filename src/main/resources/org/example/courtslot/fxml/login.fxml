<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane alignment="CENTER"
           stylesheets="@../css/styles.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.courtslot.controller.LoginController">

    <Pane maxHeight="Infinity" maxWidth="Infinity" styleClass="background" />

    <VBox alignment="CENTER"
          maxHeight="560" maxWidth="400"
          prefHeight="560" prefWidth="400"
          spacing="16" styleClass="card">

        <!--Logo-->
        <VBox alignment="CENTER" spacing="6">
            <Label text="🎾" style="-fx-font-size: 48px;" />
            <Label styleClass="brand-title" text="CourtSlot" />
            <Label styleClass="subtext" text="Gestión inteligente de pistas deportivas" />
        </VBox>

        <Separator styleClass="separator" />

        <Label styleClass="title" text="Bienvenido/a" />
        <Label styleClass="subtext" text="Introduce tus credenciales para acceder" />

        <!-- Formulario -->
        <VBox maxWidth="300" spacing="10">
            <Label styleClass="field-label" text="Email" />
            <TextField fx:id="emailField"
                       promptText="tu@email.com"
                       styleClass="input-field"
                       focusTraversable="true"
                       accessibleText="Campo de email" />

            <Label styleClass="field-label" text="Contraseña" />
            <PasswordField fx:id="passwordField"
                           styleClass="input-field"
                           focusTraversable="true"
                           accessibleText="Campo de contraseña" />
        </VBox>

        <!--error-->
        <Label fx:id="errorLabel"
               styleClass="error-label"
               wrapText="true"
               maxWidth="300" />

        <!-- Botón login-->
        <Button fx:id="loginBtn"
                maxWidth="300"
                onAction="#onIniciarSesion"
                prefHeight="44"
                styleClass="btn-primary"
                text="Iniciar sesión"
                focusTraversable="true"
                accessibleText="Botón iniciar sesión"
                mnemonicParsing="false" />

        <!--registro-->
        <HBox alignment="CENTER" spacing="5">
            <Label styleClass="subtext" text="¿No tienes cuenta?" />
            <Hyperlink onAction="#onRegister"
                       text="Regístrate aquí"
                       styleClass="link"
                       focusTraversable="true"
                       accessibleText="Ir a la página de registro" />
        </HBox>

    </VBox>

</StackPane>
