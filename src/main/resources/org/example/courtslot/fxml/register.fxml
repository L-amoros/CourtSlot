<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane alignment="CENTER"
           stylesheets="@../css/styles.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.courtslot.controller.RegisterController">

    <Pane maxHeight="Infinity" maxWidth="Infinity" styleClass="background" />

    <VBox alignment="CENTER"
          maxHeight="640" maxWidth="420"
          prefHeight="640" prefWidth="420"
          spacing="14" styleClass="card">

        <!-- Cabecera -->
        <VBox alignment="CENTER" spacing="6">
            <Label text="🏟️" style="-fx-font-size: 42px;" />
            <Label styleClass="brand-title" text="CourtSlot" />
        </VBox>

        <Separator styleClass="separator" />

        <Label styleClass="title" text="Crea tu cuenta" />
        <Label styleClass="subtext"
               text="Únete para reservar tus pistas favoritas"
               wrapText="true" maxWidth="300" />

        <!--Formulario-->
        <VBox maxWidth="300" spacing="10">
            <Label styleClass="field-label" text="Nombre completo" />
            <TextField fx:id="nombreField"
                       promptText="Tu nombre"
                       styleClass="input-field"
                       accessibleText="Campo de nombre completo" />

            <Label styleClass="field-label" text="Email" />
            <TextField fx:id="emailField"
                       promptText="tu@email.com"
                       styleClass="input-field"
                       accessibleText="Campo de email" />

            <Label styleClass="field-label" text="Contraseña" />
            <PasswordField fx:id="passwordField"
                           styleClass="input-field"
                           accessibleText="Campo de contraseña, mínimo 6 caracteres" />

            <Label styleClass="field-label" text="Confirmar contraseña" />
            <PasswordField fx:id="confirmPasswordField"
                           styleClass="input-field"
                           accessibleText="Repite la contraseña" />
        </VBox>

        <!--error o éxito-->
        <Label fx:id="errorLabel"
               styleClass="error-label"
               wrapText="true"
               maxWidth="300" />

        <!--registrar-->
        <Button fx:id="registerBtn"
                maxWidth="300"
                onAction="#onRegistrar"
                prefHeight="44"
                styleClass="btn-primary"
                text="Crear cuenta"
                accessibleText="Botón crear cuenta nueva"
                mnemonicParsing="false" />

        <!--login-->
        <HBox alignment="CENTER" spacing="5">
            <Label styleClass="subtext" text="¿Ya tienes cuenta?" />
            <Hyperlink onAction="#onLogin"
                       text="Inicia sesión"
                       styleClass="link"
                       accessibleText="Ir a la página de inicio de sesión" />
        </HBox>

    </VBox>

</StackPane>
